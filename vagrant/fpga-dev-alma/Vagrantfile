# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# FPGA Development VM – Vivado (Xilinx/AMD) + Quartus (Intel/Altera)
# Host: Windows 11, 64 GB RAM
# Guest: AlmaLinux 9 + XFCE4 desktop
#
# AlmaLinux 9 mirrors RHEL 9. Both Vivado and Quartus officially support RHEL 8/9,
# so this variant requires fewer library workarounds than the Ubuntu 24.04 one.
#
# VM creation is handled here; all software provisioning is delegated to the
# Ansible playbooks in this repository (playbooks/site.yml).
#
# Prerequisites (install on Windows host before "vagrant up"):
#   1. VMware Workstation Pro  – https://www.vmware.com/products/workstation-pro.html
#   2. Vagrant                 – https://developer.hashicorp.com/vagrant/downloads
#   3. Vagrant VMware plugin   – "vagrant plugin install vagrant-vmware-desktop"
#      (requires a paid HashiCorp license)
#
# Disk space:
#   The virtual disk is provisioned at 512 GB (config.vm.disk below).
#   Vivado (full) ~100 GB + Quartus ~40 GB + projects leaves plenty of room.
#   The first-boot provisioner automatically grows the root partition and
#   XFS filesystem to fill the expanded disk — no manual steps needed.
#
# Tool installers:
#   Drop Vivado / Quartus installer archives into the local "installers/" folder
#   (auto-created next to this Vagrantfile). They appear at /opt/fpga-installers
#   inside the VM so you can run them without re-downloading.
#
# USB / JTAG programmers:
#   Ansible pre-installs udev rules for Digilent JTAG, Xilinx Platform Cable
#   USB II, and Intel USB-Blaster / USB-Blaster II.
#   To forward a physical programmer: VM → Removable Devices → Connect.
#
# Usage:
#   vagrant up       # first boot + Ansible provisioning (~20 min)
#   vagrant reload   # reboot (apply kernel/desktop changes)
#   vagrant halt     # graceful shutdown
#   vagrant destroy  # delete VM entirely
# ---------------------------------------------------------------------------

VAGRANTFILE_API_VERSION = "2"

# ---------------------------------------------------------------------------
# Tuneable constants – adjust to taste
# ---------------------------------------------------------------------------
VM_NAME     = "fpga-dev-alma9"
VM_RAM_MB   = 32_768   # 32 GB  (leaves 32 GB for the Windows host)
VM_CPUS     = 8        # logical CPUs visible inside the VM
VM_DISK_GB  = "512GB"  # virtual disk size (provisioned on first vagrant up)
VM_VRAM_MB  = 256      # video RAM for the XFCE session
VM_3D_ACCEL = "TRUE"   # set to "FALSE" if the host GPU causes glitches

# Install Ansible via the system package manager.
INSTALL_ANSIBLE = <<~SHELL
  set -e
  . /etc/os-release
  case "$ID" in
    debian|ubuntu)
      apt-get update -y
      apt-get install -y ansible
      ;;
    almalinux|rocky|rhel|centos)
      dnf install -y epel-release
      dnf install -y ansible-core
      ;;
    *)
      echo "Unsupported OS: $ID" >&2; exit 1 ;;
  esac
SHELL

# Extra vars passed to the Ansible playbook.
# profile + features drive which roles are applied (see playbooks/site.yml).
EXTRA_VARS = {
  "profile"             => "desktop-xfce",
  "features"            => { "fpga" => true, "xrdp" => false },
  "xfce_autologin_user" => "vagrant"
}.freeze

# ---------------------------------------------------------------------------
Vagrant.configure(VAGRANTFILE_API_VERSION) do |config|

  # ── Base box ────────────────────────────────────────────────────────────
  config.vm.box         = "almalinux/9"
  config.vm.box_version = ">= 9.0.0"
  config.vm.hostname    = "fpga-dev"

  # ── Disk size ────────────────────────────────────────────────────────────
  # Requires Vagrant >= 2.2.8. The vagrant-vmware-desktop plugin handles the
  # VMDK expansion before first boot; the step-0 provisioner below grows the
  # partition and XFS filesystem to use the full allocated space.
  config.vm.disk :disk, size: VM_DISK_GB, primary: true

  # Disable the default /vagrant mount (explicit mounts are set up below).
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # ── Shared folders ──────────────────────────────────────────────────────
  # Repository root — Ansible reads roles, playbooks, and inventory from here.
  # NOTE: VMware synced folders are world-writable, so ANSIBLE_CONFIG must be
  # set explicitly in the provisioner (Ansible refuses config from world-writable dirs).
  config.vm.synced_folder "../..", "/home/vagrant/workspace/workstation"

  # FPGA project sources — edit HDL on the host, build inside the VM.
  config.vm.synced_folder "projects", "/home/vagrant/projects", create: true

  # FPGA tool installer archives (Vivado / Quartus .bin / .run files).
  config.vm.synced_folder "installers", "/opt/fpga-installers", create: true

  # ── VMware Workstation provider ─────────────────────────────────────────
  config.vm.provider "vmware_workstation" do |vmw|
    vmw.vmx["displayName"] = VM_NAME
    vmw.memory             = VM_RAM_MB
    vmw.cpus               = VM_CPUS
    vmw.gui                = true    # open VMware console on boot
    vmw.linked_clone       = false   # full clone – better I/O for large tool sets

    # ── CPU topology (4 cores × 2 sockets = 8 logical CPUs)
    vmw.vmx["cpuid.coresPerSocket"] = "4"

    # ── Video / display
    vmw.vmx["svga.vramSize"]                  = (VM_VRAM_MB * 1024 * 1024).to_s
    vmw.vmx["mks.enable3d"]                   = VM_3D_ACCEL
    vmw.vmx["mks.gl.allowBlacklistedDrivers"] = "TRUE"
    vmw.vmx["svga.autodetect"]                = "TRUE"

    # ── Memory — prevent swap thrashing during synthesis
    vmw.vmx["MemTrimRate"]          = "-1"
    vmw.vmx["mem.hotadd"]           = "FALSE"
    vmw.vmx["mainMem.useNamedFile"] = "FALSE"

    # ── Storage controller — paravirtual SCSI for better sequential I/O
    vmw.vmx["scsi0.virtualDev"] = "pvscsi"

    # ── USB controllers (required for JTAG programmers)
    vmw.vmx["usb.present"]      = "TRUE"
    vmw.vmx["ehci.present"]     = "TRUE"   # USB 2.0 (USB-Blaster, Platform Cable)
    vmw.vmx["usb_xhci.present"] = "TRUE"   # USB 3.0 (USB-Blaster II, modern Digilent)

    # ── VMware Tools integration (clipboard, drag-and-drop, shared folders)
    vmw.vmx["isolation.tools.copy.disable"]  = "FALSE"
    vmw.vmx["isolation.tools.paste.disable"] = "FALSE"
    vmw.vmx["isolation.tools.dnd.disable"]   = "FALSE"
    vmw.vmx["isolation.tools.hgfs.disable"]  = "FALSE"

    # ── Time sync
    vmw.vmx["tools.syncTime"]             = "TRUE"
    vmw.vmx["time.synchronize.continue"]  = "TRUE"
    vmw.vmx["time.synchronize.restore"]   = "TRUE"
    vmw.vmx["time.synchronize.resume"]    = "TRUE"
  end

  # ── Provisioning (three steps, matching tests/vagrant/Vagrantfile) ───────

  # Step 0: grow root partition + XFS filesystem to fill the 512 GB disk.
  # growpart is idempotent (exits 0 if already at max size).
  config.vm.provision "shell", privileged: true, name: "grow-disk", inline: <<~SHELL
    set -e
    ROOT_DEV=$(findmnt -n -o SOURCE /)
    DISK=$(lsblk -no PKNAME "$ROOT_DEV")
    PART_NUM=$(cat /sys/class/block/${ROOT_DEV##*/}/partition)
    growpart "/dev/$DISK" "$PART_NUM" || true
    xfs_growfs /
  SHELL

  # Step 1: install Ansible via the OS package manager.
  # Note: epel-release is installed here first so ansible-core is resolvable.
  config.vm.provision "shell", privileged: true, inline: INSTALL_ANSIBLE

  # Step 2: install Ansible Galaxy collections declared in requirements.yml.
  config.vm.provision "shell", privileged: false,
    inline: "cd /home/vagrant/workspace/workstation && " \
            "ansible-galaxy collection install -r requirements.yml"

  # Step 3: run the full provisioning playbook.
  # ANSIBLE_CONFIG is set explicitly because VMware synced folders are
  # world-writable and Ansible refuses to auto-load config from such dirs.
  config.vm.provision "shell", privileged: false, inline: <<~SHELL
    set -e
    REPO=/home/vagrant/workspace/workstation
    export ANSIBLE_CONFIG="$REPO/ansible.cfg"
    export ANSIBLE_ROLES_PATH="$REPO/roles"
    ansible-playbook \
      --inventory "$REPO/inventory/hosts.yml" \
      --extra-vars '#{EXTRA_VARS.to_json}' \
      "$REPO/playbooks/site.yml"
  SHELL

end
