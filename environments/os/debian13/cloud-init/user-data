#cloud-config
users:
  - name: vagrant
    groups: [sudo, adm]
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    lock_passwd: false
    # SHA-512 hash of "vagrant" (openssl passwd -6 -salt 'vagrant' 'vagrant')
    passwd: "$6$vagrant$aYdZwu4306HGdE39rROOrbSnB8G1Jser5zc9VMESSr8PouIZdgoO.OYQsFTOHXRXSYzB1oCD7571llAG6WR15."
    shell: /bin/bash

# Allow password auth so build.py can SSH in before setup.sh installs the admin key.
ssh_pwauth: true

runcmd:
  - ip a > /dev/ttyS0
  - ip r > /dev/ttyS0
  - systemctl status ssh > /dev/ttyS0

