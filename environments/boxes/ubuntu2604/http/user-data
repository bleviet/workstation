#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  network:
    version: 2
    ethernets:
      mainif:
        match:
          name: "e*"
        dhcp4: true
  storage:
    layout:
      # Direct layout: plain ext4 partition, no LVM.
      # Keeps the grow-disk Vagrantfile provisioner (resize2fs) simple.
      name: direct
  identity:
    hostname: ubuntu-vagrant
    username: vagrant
    # SHA-512 hash of "vagrant" (openssl passwd -6 -salt 'vagrant' 'vagrant')
    password: "$6$vagrant$aYdZwu4306HGdE39rROOrbSnB8G1Jser5zc9VMESSr8PouIZdgoO.OYQsFTOHXRXSYzB1oCD7571llAG6WR15."
  refresh-installer:
    update: false
  ssh:
    install-server: true
    allow-pw: true
  packages:
    - open-vm-tools
    - curl
    - ubuntu-desktop-minimal
  late-commands:
    # Enable password auth so Packer can SSH in as vagrant.
    - sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /target/etc/ssh/sshd_config
