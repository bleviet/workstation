# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Multi-machine, multi-provider test environment for workstation provisioning.
#
# Supported providers:
#   virtualbox     — Windows/Linux desktop (VirtualBox must be installed on host)
#   vmware_desktop — Windows/Linux with vagrant-vmware-desktop plugin
#   libvirt        — WSL2 / native Linux with KVM (vagrant-libvirt plugin)
#                    WSL2 setup: sudo apt install qemu-kvm libvirt-daemon-system
#                                vagrant plugin install vagrant-libvirt
#
# Usage:
#   vagrant up debian --provider=virtualbox
#   vagrant up debian-i3wm --provider=vmware_desktop   # desktop profile
#   VAGRANT_DEFAULT_PROVIDER=libvirt vagrant up ubuntu
#
# All machines are autostart: false — you must name the machine explicitly.

# Each entry: { box:, profile:, memory:, cpus:, gui: }
# gui: true opens the VM display window (VirtualBox/VMware) — useful for
#      verifying a desktop environment actually came up.
MACHINES = {
  # ── Headless / CI machines ────────────────────────────────────────────────
  "debian"    => { box: "bento/debian-13",    profile: "headless",     memory: 2048, cpus: 2, gui: false },
  "ubuntu"    => { box: "bento/ubuntu-24.04", profile: "headless",     memory: 2048, cpus: 2, gui: false },
  "almalinux" => { box: "bento/almalinux-10", profile: "headless",     memory: 2048, cpus: 2, gui: false },

  # ── Desktop profile — i3wm ────────────────────────────────────────────────
  # gui: true opens the VM display window so you can visually verify the DE.
  # Set to false to provision headlessly (faster, no window).
  "debian-i3wm" => { box: "bento/debian-13",    profile: "desktop-i3wm", memory: 4096, cpus: 2, gui: true },
  "ubuntu-i3wm" => { box: "bento/ubuntu-24.04", profile: "desktop-i3wm", memory: 4096, cpus: 2, gui: true },
  "almalinux-i3wm" => { box: "bento/almalinux-10", profile: "desktop-i3wm", memory: 4096, cpus: 2, gui: true },
}.freeze

# Install Ansible via the system package manager.
# Mirrors the install logic in bootstrap.sh, without running the playbook.
INSTALL_ANSIBLE = <<~SHELL
  set -e
  . /etc/os-release
  case "$ID" in
    debian|ubuntu)
      apt-get update -y
      apt-get install -y ansible
      ;;
    almalinux|rocky|rhel|centos)
      dnf install -y ansible-core
      ;;
    *)
      echo "Unsupported OS: $ID" >&2
      exit 1
      ;;
  esac
SHELL

Vagrant.configure("2") do |config|
  MACHINES.each do |name, cfg|
    config.vm.define name, autostart: false do |m|
      m.vm.box      = cfg[:box]
      m.vm.hostname = "workstation-test-#{name}"

      # Map repo root (two levels up from tests/vagrant/) into the VM at the expected path.
      m.vm.synced_folder "../..", "/home/vagrant/workspace/workstation"

      m.vm.provider "virtualbox" do |vb|
        vb.name   = "workstation-test-#{name}"
        vb.memory = cfg[:memory]
        vb.cpus   = cfg[:cpus]
        vb.gui    = cfg[:gui]
      end

      m.vm.provider "vmware_desktop" do |vmw|
        vmw.vmx["displayName"] = "workstation-test-#{name}"
        vmw.vmx["memsize"]     = cfg[:memory].to_s
        vmw.vmx["numvcpus"]    = cfg[:cpus].to_s
        vmw.gui                = cfg[:gui]
      end

      m.vm.provider "libvirt" do |lv|
        lv.title  = "workstation-test-#{name}"
        lv.memory = cfg[:memory]
        lv.cpus   = cfg[:cpus]
      end

      # Step 1: install Ansible inside the VM via system package manager.
      m.vm.provision "shell", privileged: true, inline: INSTALL_ANSIBLE

      # Step 2: install Ansible Galaxy collections (requirements.yml uses
      # collections:, which ansible_local's galaxy_role_file does not handle).
      m.vm.provision "shell", privileged: false,
        inline: "cd /home/vagrant/workspace/workstation && " \
                "ansible-galaxy collection install -r requirements.yml"

      # Step 3: run the full provisioning playbook.
      # Uses explicit env vars so paths are never relative to an ambiguous CWD.
      # ANSIBLE_CONFIG is set explicitly because VMware synced folders are
      # world-writable and Ansible refuses to auto-load cfg from such dirs.
      # profile and features are injected via extra-vars so the VM inventory
      # does not need host_vars entries for non-localhost hostnames.
      m.vm.provision "shell", privileged: false, inline: <<~SHELL
        set -e
        REPO=/home/vagrant/workspace/workstation
        export ANSIBLE_CONFIG="$REPO/ansible.cfg"
        export ANSIBLE_ROLES_PATH="$REPO/roles"
        ansible-playbook \
          --inventory "$REPO/inventory/hosts.yml" \
          --extra-vars '{"profile": "#{cfg[:profile]}", "features": {"fpga": false, "xrdp": false}}' \
          "$REPO/playbooks/site.yml"
      SHELL
    end
  end
end
