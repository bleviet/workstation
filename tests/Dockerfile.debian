FROM debian:12

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    ansible curl git sudo \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash user && \
    echo 'user ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers

USER user
WORKDIR /home/user/workspace/workstation

COPY --chown=user:user . .

RUN ansible-galaxy collection install -r requirements.yml

# Validate playbook + role structure without executing any tasks.
# Full integration runs on a real machine via bootstrap.sh.
RUN ansible-playbook playbooks/site.yml --syntax-check && \
    ansible-playbook playbooks/dotfiles.yml --syntax-check
