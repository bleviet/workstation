# OS-specific shell configuration — generated by Ansible, do not edit manually.
# Auto-sourced via the ~/.config/shell/*.sh glob in .bashrc and .zshrc.
{% if ansible_os_family == "Debian" %}
alias apt-search="apt-cache search"
alias apt-install="sudo apt install"
alias apt-update="sudo apt update && sudo apt upgrade"
alias apt-clean="sudo apt autoremove && sudo apt autoclean"
{% elif ansible_os_family == "RedHat" %}
alias dnf-install="sudo dnf install -y"
alias dnf-update="sudo dnf update -y"
alias dnf-remove="sudo dnf remove -y"
alias dnf-search="dnf search"
{% endif %}
